{
  "name": "octovox-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OCTOVOX voice-cleanup console UI (React + TypeScript), built into the Flask app's static/ui/ directory.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "watch": "vite build --watch",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wavesurfer.js": "7.12.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
